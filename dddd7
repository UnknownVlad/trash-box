@EventListener
public void onPaused(ConsumerPausedEvent event) {
    String containerId = resolveParentContainerId(event.getSource());
    if (containerId == null) {
        log.debug("ConsumerPausedEvent: не удалось определить родительский контейнер, пропускаем");
        return;
    }
    Semaphore semaphore = pauseSemaphores.get(containerId);
    if (semaphore == null) {
        log.debug("ConsumerPausedEvent для контейнера с id {}, но операция паузы не ожидается, пропускаем", containerId);
        return;
    }
    Collection<TopicPartition> partitions = event.getPartitions();
    int count = CollectionUtils.isEmpty(partitions) ? 1 : partitions.size();
    semaphore.release(count);
    log.debug("Обработано ConsumerPausedEvent для контейнера с id {}: освобождено {} разрешений, доступно теперь {}",
            containerId, count, semaphore.availablePermits());
}

@EventListener
public void onResumed(ConsumerResumedEvent event) {
    String containerId = resolveParentContainerId(event.getSource());
    if (containerId == null) {
        log.debug("ConsumerResumedEvent: не удалось определить родительский контейнер, пропускаем");
        return;
    }
    Semaphore semaphore = resumeSemaphores.get(containerId);
    if (semaphore == null) {
        log.debug("ConsumerResumedEvent для контейнера с id {}, но операция возобновления не ожидается, пропускаем", containerId);
        return;
    }
    Collection<TopicPartition> partitions = event.getPartitions();
    int count = CollectionUtils.isEmpty(partitions) ? 1 : partitions.size();
    semaphore.release(count);
    log.debug("Обработано ConsumerResumedEvent для контейнера с id {}: освобождено {} разрешений, доступно теперь {}",
            containerId, count, semaphore.availablePermits());
}

/**
 * Возвращает РОДИТЕЛЬСКИЙ containerId (исходный, под которым лежит семафор)
 * для контейнера-источника события. Работает надёжно даже когда id одного
 * контейнера является префиксом другого, потому что матчит по фактической
 * принадлежности дочернего контейнера родителю, а не по строке id.
 */
private String resolveParentContainerId(Object source) {
    if (!(source instanceof MessageListenerContainer eventContainer)) {
        return null;
    }

    // проходим по всем зарегистрированным РОДИТЕЛЬСКИМ контейнерам
    for (MessageListenerContainer parent : kafkaListenerEndpointRegistry.getListenerContainers()) {
        // 1) источник и есть сам родитель (concurrency = 1, событие от него же)
        if (parent == eventContainer) {
            return parent.getListenerId();
        }
        // 2) источник — дочерний контейнер этого родителя
        if (parent instanceof ConcurrentMessageListenerContainer<?, ?> concurrent) {
            List<?> children = concurrent.getContainers();
            if (children != null && children.contains(eventContainer)) {
                return parent.getListenerId();
            }
        }
    }
    log.debug("Не удалось сопоставить источник события с родительским контейнером");
    return null;
}