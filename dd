/**
     * Текущие committed offset группы для партиций контейнера с данным listenerId.
     *
     * @param listenerId id контейнера
     * @return Map: партиция -> committed offset
     */
    public Map<TopicPartition, Long> getCommittedOffsets(String listenerId) throws Exception {
        MessageListenerContainer listenerContainer = findContainer(listenerId);
        String groupId = listenerContainer.getGroupId();

        Map<TopicPartition, OffsetAndMetadata> committed = adminClient
                .listConsumerGroupOffsets(groupId)
                .partitionsToOffsetAndMetadata()
                .get(ADMIN_TIMEOUT_SEC, TimeUnit.SECONDS);

        Map<TopicPartition, Long> result = new HashMap<>();
        committed.forEach((tp, meta) -> {
            if (meta != null) {
                result.put(tp, meta.offset());
            }
        });
        log.debug("Контейнер с id {}: получены committed offset для {} партиций", listenerId, result.size());
        return result;
    }



    /**
         * Offset, соответствующий таймштампу, для партиций контейнера с данным listenerId.
         * Партиции без сообщений после таймштампа (offset == -1) в результат не входят.
         *
         * @param listenerId id контейнера
         * @param timestamp  метка времени в мс
         * @return Map: партиция -> offset для таймштампа
         */
        public Map<TopicPartition, Long> getOffsetsForTimestamp(String listenerId, long timestamp) throws Exception {
            MessageListenerContainer listenerContainer = findContainer(listenerId);
            Collection<TopicPartition> partitions = listenerContainer.getAssignedPartitions();

            if (partitions == null || partitions.isEmpty()) {
                log.warn("Контейнер с id {} не имеет назначенных партиций, offset по timestamp не получены", listenerId);
                return Map.of();
            }

            Map<TopicPartition, OffsetSpec> query = partitions.stream()
                    .collect(Collectors.toMap(tp -> tp, tp -> OffsetSpec.forTimestamp(timestamp)));

            Map<TopicPartition, ListOffsetsResult.ListOffsetsResultInfo> found =
                    adminClient.listOffsets(query).all().get(ADMIN_TIMEOUT_SEC, TimeUnit.SECONDS);

            Map<TopicPartition, Long> result = new HashMap<>();
            found.forEach((tp, info) -> {
                if (info.offset() != -1) {
                    result.put(tp, info.offset());
                }
            });
            log.debug("Контейнер с id {}: получены offset по timestamp {} для {} партиций",
                    listenerId, timestamp, result.size());
            return result;
        }

        /**
             * Считает, какие партиции и на какой offset двигать при сбросе на один timestamp,
             * с проверкой "только назад": двигаем только там, где target < committed.
             *
             * @return Map: партиция -> целевой offset (только те, что нужно откатить назад)
             */
            private Map<TopicPartition, Long> calculateBackwardOnlyOffsets(String listenerId, long timestamp)
                    throws Exception {

                Map<TopicPartition, Long> targetOffsets = getOffsetsForTimestamp(listenerId, timestamp);
                if (targetOffsets.isEmpty()) {
                    log.debug("Контейнер с id {}: нет target offset по timestamp {}", listenerId, timestamp);
                    return Map.of();
                }

                Map<TopicPartition, Long> committed = getCommittedOffsets(listenerId);

                Map<TopicPartition, Long> toSeek = new HashMap<>();
                targetOffsets.forEach((tp, target) -> {
                    Long committedOffset = committed.get(tp);
                    if (committedOffset == null) {
                        log.debug("Партиция {}: нет committed offset, пропускаем во избежание неожиданного скачка", tp);
                        return;
                    }
                    if (target < committedOffset) {
                        toSeek.put(tp, target);
                        log.info("Партиция {}: откат offset с {} на {} (timestamp {})",
                                tp, committedOffset, target, timestamp);
                    } else {
                        log.info("Партиция {}: целевой offset {} >= текущего {}, пропускаем во избежание потери сообщений",
                                tp, target, committedOffset);
                    }
                });
                return toSeek;
            }
            /**
                 * Сброс offset контейнера на timestamp, только назад.
                 * Пауза -> расчёт -> seek -> возобновление, потокобезопасно под локом.
                 */
                public void resetOffsetToTimestamp(String containerId, long timestamp) {
                    withLock(containerId, "сброс offset", () -> {
                        log.info("Начало сброса offset контейнера с id {} на timestamp {}", containerId, timestamp);

                        AbstractResetOffsetConsumerSeekAware consumerSeekAware = findSeekAware(containerId);

                        pauseContainerInternal(containerId);
                        try {
                            Map<TopicPartition, Long> toSeek = calculateBackwardOnlyOffsets(containerId, timestamp);
                            if (toSeek.isEmpty()) {
                                log.info("Для контейнера с id {} нет партиций, требующих отката offset "
                                        + "(все целевые позиции не раньше текущих либо нет назначенных партиций)", containerId);
                                return;
                            }
                            applySeek(containerId, consumerSeekAware, toSeek);
                            log.info("Offset контейнера с id {} успешно сброшен на timestamp {} для {} партиций",
                                    containerId, timestamp, toSeek.size());
                        } catch (Exception e) {
                            log.error("Ошибка сброса offset для контейнера с id {} на timestamp {}", containerId, timestamp, e);
                            throw new IllegalStateException(
                                    String.format("Ошибка сброса offset для контейнера с id %s на timestamp %d", containerId, timestamp), e);
                        } finally {
                            log.debug("Возобновление контейнера с id {} после сброса offset", containerId);
                            resumeContainerInternal(containerId);
                        }
                    });
                }
                /**
                     * Применяет seek к отобранным партициям через существующий метод
                     * seekToOffset абстрактного класса. seekToOffset сам маршрутизирует
                     * seek в нужный дочерний consumer-поток через getSeekCallbackFor.
                     */
                    private void applySeek(String containerId, AbstractResetOffsetConsumerSeekAware consumerSeekAware,
                                           Map<TopicPartition, Long> toSeek) {
                        toSeek.forEach((tp, offset) -> {
                            log.debug("Контейнер с id {}: seek партиции {} на offset {}", containerId, tp, offset);
                            consumerSeekAware.seekToOffset(tp.topic(), tp.partition(), offset);
                        });
                    }